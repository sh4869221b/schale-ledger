{
  "name": "@schale-ledger/db",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "migrate:local": "wrangler d1 migrations apply DB --local --persist-to ../../.wrangler/d1-local --config ../../apps/web/wrangler.jsonc",
    "migrate:remote:dev": "wrangler d1 migrations apply DB --remote --env dev --config ../../apps/web/wrangler.jsonc",
    "migrate:remote:prod": "wrangler d1 migrations apply DB --remote --config ../../apps/web/wrangler.jsonc"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.65.0"
  }
}
