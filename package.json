{
  "name": "schale-ledger",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd ./apps/web dev",
    "build": "bun run --cwd ./apps/web build",
    "check": "bun run --cwd ./apps/web check",
    "test": "bun test",
    "db:migrate:local": "bun run --cwd ./packages/db migrate:local"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
