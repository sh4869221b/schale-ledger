{
  "name": "schale-ledger",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd ./apps/web dev",
    "build": "bun run --cwd ./apps/web build",
    "check": "bun run --cwd ./apps/web check",
    "test": "bun test",
    "db:migrate:legacy": "bun run scripts/migrate.ts",
    "db:migrate:legacy:dev": "DATABASE_URL=$NEON_DATABASE_URL_DEV bun run db:migrate:legacy",
    "db:migrate:legacy:prod": "DATABASE_URL=$NEON_DATABASE_URL_PROD bun run db:migrate:legacy",
    "db:migrate:local": "bun run --cwd ./packages/db migrate:local",
    "deploy:dev": "bun run --cwd ./apps/web deploy:dev",
    "deploy:prod": "bun run --cwd ./apps/web deploy:prod"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/pg": "^8.15.6",
    "drizzle-orm": "^0.44.7",
    "pg": "^8.16.3",
    "typescript": "^5.9.3"
  }
}
