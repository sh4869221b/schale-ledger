{
  "name": "@schale-ledger/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "preview": "vite preview",
    "deploy:dev": "bun run build && wrangler deploy --env dev",
    "deploy:prod": "bun run build && wrangler deploy --env prod"
  },
  "dependencies": {
    "@schale-ledger/core": "workspace:*",
    "@schale-ledger/db": "workspace:*",
    "@schale-ledger/ui": "workspace:*",
    "@sveltejs/adapter-cloudflare": "latest",
    "@sveltejs/kit": "latest",
    "jose": "^6.1.0",
    "svelte": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.0",
    "@tailwindcss/vite": "^4.1.14",
    "@sveltejs/vite-plugin-svelte": "latest",
    "svelte-check": "latest",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite": "latest",
    "wrangler": "^4.65.0"
  }
}
